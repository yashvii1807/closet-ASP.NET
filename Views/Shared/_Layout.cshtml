    <nav class="navbar navbar-expand-lg bg-light shadow-sm px-5 py-3">
        <a class="navbar-brand fw-bold fs-4" href="#">Closet</a>

        <div class="collapse navbar-collapse justify-content-center">
            <ul class="navbar-nav gap-4">
                <li class="nav-item"><a class="nav-link text-dark" href="#">Men</a></li>
                <li class="nav-item"><a class="nav-link text-dark" href="#">Women</a></li>
                <li class="nav-item"><a class="nav-link text-dark" href="#">About</a></li>
                <li class="nav-item"><a class="nav-link text-dark" href="#">Contact</a></li>
            </ul>
        </div>

        <div class="d-flex gap-3">
            <a class="btn btn-danger px-4">Login</a>
            <a class="btn btn-danger px-4">Register</a>
        </div>
    </nav>

    @RenderBody()

    @await RenderSectionAsync("Scripts", required: false)
