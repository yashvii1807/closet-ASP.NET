<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin Dashboard - Closet</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <!-- Custom Admin CSS -->
    <link href="~/css/admin.css" rel="stylesheet" />
    
</head>
<body class="admin-body">
    <div class="admin-layout d-flex">
        
        <!-- Sidebar -->
        <aside class="admin-sidebar d-flex flex-column p-4">
            <div class="sidebar-logo d-flex align-items-center mb-5">
                <div class="logo-icon bg-danger text-white rounded d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 40px; height: 40px;">
                    <i class="bi bi-bag"></i>
                </div>
                <h4 class="mb-0 fw-bold">Closet<span class="text-danger">.</span></h4>
            </div>

            @{
                var activePage = ViewData["ActivePage"]?.ToString() ?? "Overview";
            }
            <nav class="sidebar-nav flex-grow-1">
                <div class="nav-item mb-2">
                    <a href="/Admin/Index" class="nav-link @(activePage == "Overview" ? "active text-white bg-danger shadow-sm" : "text-secondary") d-flex align-items-center gap-3 py-2 px-3 rounded">
                        <i class="bi bi-grid"></i> Overview
                    </a>
                </div>
                <div class="nav-item mb-2">
                    <a href="/Admin/Products" class="nav-link @(activePage == "Products" ? "active text-white bg-danger shadow-sm" : "text-secondary") d-flex align-items-center gap-3 py-2 px-3 rounded">
                        <i class="bi bi-box-seam"></i> Products
                    </a>
                </div>
                <div class="nav-item mb-2">
                    <a href="/Admin/Orders" class="nav-link @(activePage == "Orders" ? "active text-white bg-danger shadow-sm" : "text-secondary") d-flex align-items-center gap-3 py-2 px-3 rounded">
                        <i class="bi bi-cart3"></i> Orders
                    </a>
                </div>
                 <div class="nav-item mb-2">
                    <a href="/Admin/Users" class="nav-link @(activePage == "Users" ? "active text-white bg-danger shadow-sm" : "text-secondary") d-flex align-items-center gap-3 py-2 px-3 rounded">
                        <i class="bi bi-people"></i> Users
                    </a>
                </div>
                <div class="nav-item mb-2">
                    <a href="/Admin/Reviews" class="nav-link @(activePage == "Reviews" ? "active text-white bg-danger shadow-sm" : "text-secondary") d-flex align-items-center gap-3 py-2 px-3 rounded">
                        <i class="bi bi-chat-left-text"></i> Reviews
                    </a>
                </div>
                <div class="nav-item mb-2">
                    <a href="/Admin/Messages" class="nav-link @(activePage == "Messages" ? "active text-white bg-danger shadow-sm" : "text-secondary") d-flex align-items-center gap-3 py-2 px-3 rounded">
                        <i class="bi bi-envelope"></i> Messages
                    </a>
                </div>
               
            </nav>

            <div class="sidebar-footer mt-auto">
                <a href="/" class="nav-link text-secondary d-flex align-items-center gap-3 py-2 px-3">
                    <i class="bi bi-box-arrow-left"></i> Back to Store
                </a>
            </div>
        </aside>

        <!-- Main Content Wrapper -->
        <main class="admin-main flex-grow-1 bg-light">
            @RenderBody()
        </main>
    </div>
</body>
</html>
