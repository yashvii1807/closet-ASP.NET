@{
    Layout = "_AdminLayout";
    ViewData["ActivePage"] = "Users";
    var users = ViewBag.Users as IEnumerable<dynamic>;
}

<div class="p-4 p-md-5">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Users</h1>
            <p class="text-secondary mb-0">Manage your store efficiently</p>
        </div>
        <div class="user-avatar rounded-circle d-flex align-items-center justify-content-center fw-bold text-danger" style="width: 42px; height: 42px; background-color: #ffeaf0; font-size: 1.1rem;">
            A
        </div>
    </div>

    <!-- Filters/Controls Toolbar -->
    <div class="d-flex flex-wrap gap-3 align-items-center mb-4">
        <div class="search-box position-relative flex-grow-1">
            <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-secondary" style="margin-left: 1.25rem !important;"></i>
            <input type="text" class="form-control rounded-pill border-0 shadow-sm py-2" placeholder="Search users..." style="padding-left: 3rem;">
        </div>
        
        <select class="form-select border-0 shadow-sm rounded-pill w-auto px-4 py-2 text-secondary">
            <option>All Roles</option>
            <option>Admin</option>
            <option>User</option>
        </select>

        <button class="btn btn-light bg-white border-0 shadow-sm rounded-pill px-4 fw-medium py-2">Export</button>
        <a href="/Admin/AddUser" class="btn btn-danger rounded-pill px-4 shadow-sm fw-medium d-flex align-items-center gap-2 py-2 text-decoration-none text-white text-center">
            <i class="bi bi-plus"></i> Add User
        </a>
    </div>

    <!-- Users Table Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle mb-0 admin-table">
                <thead class="text-secondary small" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                    <tr>
                        <th class="border-0 ps-4 py-3 font-weight-norm text-uppercase">User</th>
                        <th class="border-0 py-3 font-weight-norm text-uppercase text-center">Role</th>
                        <th class="border-0 py-3 font-weight-norm text-uppercase text-center">Contact</th>
                        <th class="border-0 py-3 font-weight-norm text-uppercase text-center">Join Date</th>
                        <th class="border-0 pe-4 py-3 font-weight-norm text-uppercase text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var user in users)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    @if(user.HasLogo)
                                    {
                                        <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <i class="bi bi-tree text-success fs-5"></i>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="rounded-circle bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <i class="bi bi-person-fill text-secondary fs-4"></i>
                                        </div>
                                    }
                                    <div>
                                        <div class="fw-bold text-dark" style="font-size: 0.95rem;">@user.Name</div>
                                        <div class="text-secondary" style="font-size: 0.8rem;">@user.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3 text-center">
                                @if (user.Role == "User")
                                {
                                    <span class="badge rounded-pill fw-medium" style="color: #3b82f6; background-color: rgba(59, 130, 246, 0.1); padding: 0.5rem 0.8rem;">
                                        <i class="bi bi-person me-1"></i> User
                                    </span>
                                }
                                else if (user.Role == "Admin")
                                {
                                    <span class="badge rounded-pill fw-medium" style="color: #a855f7; background-color: rgba(168, 85, 247, 0.1); padding: 0.5rem 0.8rem;">
                                        <i class="bi bi-shield-check me-1"></i> Admin
                                    </span>
                                }
                            </td>
                            <td class="py-3 text-center text-secondary" style="font-size: 0.9rem;">
                                @user.Contact
                            </td>
                            <td class="py-3 text-center text-secondary" style="font-size: 0.9rem;">
                                @user.JoinDate
                            </td>
                            <td class="pe-4 py-3 text-center">
                                <div class="d-flex gap-2 justify-content-center">
                                    <button class="btn btn-sm btn-light bg-transparent border-0 text-secondary p-1">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <form action="/Admin/DeleteUser" method="post" onsubmit="return confirm('Are you sure you want to delete this user?');" style="display:inline;">
                                        <input type="hidden" name="email" value="@user.Email" />
                                        <button type="submit" class="btn btn-sm btn-light bg-transparent border-0 text-secondary p-1">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
