        new { Name = "Anshil Bhuva", Email = "anshilbhuva@gmail.com", Role = "Admin", Contact = "1234567890", JoinDate = "1/18/2026", HasLogo = false },
        new { Name = "Prem Dipenbhai Shah", Email = "pshah627@rku.ac.in", Role = "User", Contact = "98977878787", JoinDate = "1/15/2026", HasLogo = false },
