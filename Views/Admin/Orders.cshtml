@{
    Layout = "_AdminLayout";
    ViewData["ActivePage"] = "Orders";
}

<div class="p-4 p-md-5">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Orders</h1>
            <p class="text-secondary mb-0">Manage your store efficiently</p>
        </div>
        <div class="user-avatar rounded-circle d-flex align-items-center justify-content-center fw-bold text-danger" style="width: 42px; height: 42px; background-color: #ffeaf0; font-size: 1.1rem;">
            A
        </div>
    </div>

    <!-- Filters/Controls Toolbar -->
    <div class="d-flex flex-wrap gap-3 align-items-center mb-4">
        <div class="search-box position-relative flex-grow-1">
            <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-secondary" style="margin-left: 1.25rem !important;"></i>
            <input type="text" class="form-control rounded-pill border-0 shadow-sm py-2" placeholder="Search orders..." style="padding-left: 3rem;">
        </div>
        
        <select class="form-select border-0 shadow-sm rounded-pill w-auto px-4 py-2 text-secondary">
            <option>All Status</option>
            <option>Pending</option>
            <option>Processing</option>
            <option>Completed</option>
            <option>Cancelled</option>
        </select>
        

        <button class="btn btn-light bg-white border-0 shadow-sm rounded-pill px-4 fw-medium py-2">Export CSV</button>
    </div>

    <!-- Orders Table Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="min-height: 400px;">
        <div class="table-responsive h-100">
            <table class="table align-middle mb-0 admin-table w-100">
                <thead class="text-secondary small" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                    <tr>
                        <th class="border-0 ps-4 py-3 font-weight-norm text-uppercase">Order ID</th>
                        <th class="border-0 py-3 font-weight-norm text-uppercase text-center">Customer</th>
                        <th class="border-0 py-3 font-weight-norm text-uppercase text-center">Date</th>
                        <th class="border-0 py-3 font-weight-norm text-uppercase text-center">Total</th>
                        <th class="border-0 py-3 font-weight-norm text-uppercase text-center">Status</th>
                        <th class="border-0 pe-4 py-3 font-weight-norm text-uppercase text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    <tr>
                        <td colspan="6" class="border-0">
                            <div class="d-flex flex-column align-items-center justify-content-center" style="height: 300px;">
                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mb-3 text-secondary" style="width: 60px; height: 60px;">
                                    <i class="bi bi-search" style="font-size: 1.25rem;"></i>
                                </div>
                                <h5 class="fw-bold mb-0 text-dark">No orders found</h5>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
