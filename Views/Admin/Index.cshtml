@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Overview";
    ViewData["ActivePage"] = "Overview";
}

<div class="p-4 p-md-5 pt-4">
    <!-- Header Area -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h3 class="fw-bold mb-1 text-dark" style="font-size: 1.5rem; letter-spacing: -0.5px;">Overview</h3>
            <p class="text-secondary mb-0" style="font-size: 0.9rem;">Manage your store efficiently</p>
        </div>
        <div class="user-avatar rounded-circle d-flex align-items-center justify-content-center fw-bold text-danger" style="width: 42px; height: 42px; background-color: #ffeaf0; font-size: 1.1rem;">
            A
        </div>
    </div>

    <!-- Cards Row -->
    <div class="row g-4 d-flex">
        <!-- Card 1 -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 rounded-4 shadow-sm h-100 p-4" style="background-color: #ffffff;">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="d-flex flex-column">
                        <p class="text-secondary mb-2 fw-medium" style="font-size: 0.85rem;">Total Products</p>
                        <h3 class="fw-bold mb-0 text-dark" style="font-size: 1.8rem; letter-spacing: -0.5px;">3</h3>
                    </div>
                    <div class="icon-box rounded-3 d-flex align-items-center justify-content-center flex-shrink-0 text-danger" style="width: 42px; height: 42px; background-color: #ffeaf0;">
                        <i class="bi bi-box fs-5"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card 2 -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 rounded-4 shadow-sm h-100 p-4" style="background-color: #ffffff;">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="d-flex flex-column">
                        <p class="text-secondary mb-2 fw-medium" style="font-size: 0.85rem;">Total Orders</p>
                        <h3 class="fw-bold mb-0 text-dark" style="font-size: 1.8rem; letter-spacing: -0.5px;">0</h3>
                    </div>
                    <div class="icon-box rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 42px; height: 42px; background-color: #e9f2ff; color: #3b82f6;">
                        <i class="bi bi-cart3 fs-5"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card 3 -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 rounded-4 shadow-sm h-100 p-4" style="background-color: #ffffff;">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="d-flex flex-column">
                        <p class="text-secondary mb-2 fw-medium" style="font-size: 0.85rem;">Total Revenue</p>
                        <h3 class="fw-bold mb-0 text-dark" style="font-size: 1.8rem; letter-spacing: -0.5px;">₹0</h3>
                    </div>
                    <div class="icon-box rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 42px; height: 42px; background-color: #eafbee; color: #10b981;">
                        <i class="bi bi-currency-dollar fs-5"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card 4 -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card border-0 rounded-4 shadow-sm h-100 p-4" style="background-color: #ffffff;">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="d-flex flex-column">
                        <p class="text-secondary mb-2 fw-medium" style="font-size: 0.85rem;">Total Users</p>
                        <h3 class="fw-bold mb-0 text-dark" style="font-size: 1.8rem; letter-spacing: -0.5px;">8</h3>
                    </div>
                    <div class="icon-box rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 42px; height: 42px; background-color: #f3ebff; color: #8b5cf6;">
                        <i class="bi bi-people fs-5"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

