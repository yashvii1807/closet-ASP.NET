@{
    Layout = "_AdminLayout";
    ViewData["ActivePage"] = "Messages";

    var messages = new[] {
        new { Name = "dfg", Email = "hcv@gmail.com", Subject = "dfvfdvbsfd", Status = "Open" }
    };
}

<div class="p-4 p-md-5">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Contacts</h1>
            <p class="text-secondary mb-0">Manage your store efficiently</p>
        </div>
        <div class="user-avatar rounded-circle d-flex align-items-center justify-content-center fw-bold text-danger" style="width: 42px; height: 42px; background-color: #ffeaf0; font-size: 1.1rem;">
            A
        </div>
    </div>

    <!-- Filters/Controls Toolbar -->
    <div class="d-flex flex-wrap gap-3 align-items-center mb-4">
        <div class="search-box position-relative flex-grow-1">
            <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-secondary" style="margin-left: 1.25rem !important;"></i>
            <input type="text" class="form-control rounded-pill border-0 shadow-sm py-2" placeholder="Search messages..." style="padding-left: 3rem;">
        </div>
        
        <select class="form-select border-0 shadow-sm rounded-pill w-auto px-4 py-2 text-secondary">
            <option>All Status</option>
            <option>Open</option>
            <option>Closed</option>
        </select>

        <button class="btn btn-light bg-white border-0 shadow-sm rounded-pill px-4 fw-medium py-2">Export</button>
        <button class="btn btn-danger rounded-pill px-4 shadow-sm fw-medium d-flex align-items-center gap-2 py-2">
            <i class="bi bi-plus"></i> Add Message
        </button>
    </div>

    <!-- Contacts/Messages Table Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle mb-0 admin-table">
                <thead class="text-secondary small" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                    <tr>
                        <th class="border-0 ps-4 py-3 font-weight-norm text-uppercase">Name</th>
                        <th class="border-0 py-3 font-weight-norm text-uppercase">Email</th>
                        <th class="border-0 py-3 font-weight-norm text-uppercase">Subject</th>
                        <th class="border-0 py-3 font-weight-norm text-uppercase text-center">Status</th>
                        <th class="border-0 pe-4 py-3 font-weight-norm text-uppercase text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var msg in messages)
                    {
                        <tr>
                            <td class="ps-4 py-3 fw-bold text-dark" style="font-size: 0.95rem;">
                                @msg.Name
                            </td>
                            <td class="py-3 text-secondary" style="font-size: 0.9rem;">
                                @msg.Email
                            </td>
                            <td class="py-3 text-dark" style="font-size: 0.9rem;">
                                @msg.Subject
                            </td>
                            <td class="py-3 text-center">
                                @if(msg.Status == "Open")
                                {
                                    <span class="badge rounded-pill fw-medium text-dark" style="color: #d97706 !important; background-color: #fef3c7; padding: 0.4rem 1rem;">
                                        @msg.Status
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill fw-medium text-dark" style="color: #16a34a !important; background-color: #dcfce7; padding: 0.4rem 1rem;">
                                        @msg.Status
                                    </span>
                                }
                            </td>
                            <td class="pe-4 py-3 text-center">
                                <div class="d-flex gap-2 justify-content-center">
                                    <button class="btn btn-sm btn-light bg-transparent border-0 text-secondary p-1">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="btn btn-sm btn-light bg-transparent border-0 text-secondary p-1">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
