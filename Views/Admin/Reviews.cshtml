@{
    Layout = "_AdminLayout";
    ViewData["ActivePage"] = "Reviews";

    var reviews = new[] {
        new { Name = "abc", Email = "kjh@sf.com", Product = "Pantt", Rating = "5/5", Text = "hbx", Date = "2/18/2026" },
        new { Name = "Anshil", Email = "anshilbhuva9251@gmail.com", Product = "T-Shirt", Rating = "5/5", Text = "nice as above product like in image really good product", Date = "1/20/2026" },
        new { Name = "Anshil", Email = "anshilbhuva9254@gmail.com", Product = "Pantt", Rating = "5/5", Text = "very good product", Date = "1/20/2026" }
    };
}

<div class="p-4 p-md-5">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Reviews</h1>
            <p class="text-secondary mb-0">Manage your store efficiently</p>
        </div>
        <div class="user-avatar bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center fw-semibold" style="width: 45px; height: 45px;">
            A
        </div>
    </div>

    <!-- Review Management Bar -->
    <div class="card border-0 shadow-sm rounded-pill mb-4 px-2">
        <div class="card-body d-flex justify-content-between align-items-center py-2">
            <span class="ms-3 fw-bold text-dark" style="font-size: 0.95rem;">Review Management</span>
            <button class="btn btn-light bg-white border shadow-sm rounded-pill px-4 fw-medium py-2 text-dark" style="font-size: 0.85rem;">Export</button>
        </div>
    </div>

    <!-- Reviews Table Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle mb-0 admin-table">
                <thead class="text-secondary small" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                    <tr>
                        <th class="border-0 ps-4 py-3 font-weight-norm text-uppercase">User</th>
                        <th class="border-0 py-3 font-weight-norm text-uppercase">Product</th>
                        <th class="border-0 py-3 font-weight-norm text-uppercase text-center">Rating</th>
                        <th class="border-0 py-3 font-weight-norm text-uppercase" style="width: 35%;">Review</th>
                        <th class="border-0 py-3 font-weight-norm text-uppercase text-center">Date</th>
                        <th class="border-0 pe-4 py-3 font-weight-norm text-uppercase text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var review in reviews)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                        <i class="bi bi-person-fill text-secondary fs-4"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark" style="font-size: 0.95rem;">@review.Name</div>
                                        <div class="text-secondary" style="font-size: 0.8rem;">@review.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3">
                                <span class="fw-bold text-danger">@review.Product</span>
                            </td>
                            <td class="py-3 text-center">
                                <span class="badge rounded-pill fw-bold" style="color: #d97706; background-color: #fef3c7; padding: 0.5rem 0.8rem; font-size: 0.8rem;">
                                    <i class="bi bi-star-fill text-warning me-1"></i> @review.Rating
                                </span>
                            </td>
                            <td class="py-3 text-secondary" style="font-size: 0.9rem;">
                                @review.Text
                            </td>
                            <td class="py-3 text-center text-secondary" style="font-size: 0.9rem;">
                                @review.Date
                            </td>
                            <td class="pe-4 py-3 text-center">
                                <button class="btn btn-sm btn-light bg-transparent border-0 text-secondary p-1">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
