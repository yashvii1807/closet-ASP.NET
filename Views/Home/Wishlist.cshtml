@{
    ViewData["Title"] = "My Wishlist";
    var wishlistItems = ViewBag.WishlistItems as List<Closet_ASP.NET.Models.Product> ?? new List<Closet_ASP.NET.Models.Product>();
}

<div class="container-fluid px-5 py-5" style="min-height: 55vh;">
    
    @if (wishlistItems.Count == 0)
    {
        <!-- Empty Wishlist -->
        <div class="d-flex flex-column align-items-center justify-content-center text-center py-5">
            <div class="mb-4" style="color: #cbd5e1;">
                <svg width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                </svg>
            </div>
            <h2 class="fw-bold mb-3" style="color: #1a202c; font-size: 1.8rem;">Your wishlist is empty</h2>
            <p class="text-secondary mb-4" style="font-size: 1.05rem;">Add your favorite items to your wishlist to see them here.</p>
            <a href="/" class="btn btn-danger px-4 py-3 rounded-3 fw-semibold text-white" style="background-color: #e2154c;">Continue Shopping</a>
        </div>
    }
    else
    {
        <h1 class="fw-bold mb-5" style="color: #1a202c; font-size: 2rem;">My Wishlist</h1>
        
        <div class="row">
            @foreach(var item in wishlistItems)
            {
                var imgSrc = item.Images != null && item.Images.Count > 0 ? item.Images[0] : "https://placehold.co/400x500?text=" + item.Title;
                <div class="col-md-3 col-sm-6 mb-4">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 bg-white p-0">
                        <div class="position-relative bg-light d-flex justify-content-center align-items-center overflow-hidden" style="aspect-ratio: 3/4;">
                            <img src="@imgSrc" alt="@item.Title" class="w-100 h-100 object-fit-cover">
                            <!-- Delete floating button -->
                            <a href="/Home/RemoveFromWishlist/@item.Id" class="position-absolute bg-white border border-light shadow-sm rounded-circle d-flex align-items-center justify-content-center text-danger text-decoration-none" style="top: 15px; right: 15px; width: 35px; height: 35px;">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                        
                        <div class="card-body p-4 text-start d-flex flex-column">
                            <h5 class="fw-bold text-dark mb-2 mt-1" style="font-size: 1.05rem;">@item.Title</h5>
                            <div class="fw-bold mb-4" style="color: #e2154c; font-size: 1.25rem;">₹@item.Price</div>
                            
                            <a href="/Home/AddToCart/@item.Id" class="btn btn-danger w-100 rounded-3 py-2 fw-semibold d-flex align-items-center justify-content-center gap-2 mt-auto text-decoration-none text-white" style="background-color: #e2154c;">
                                <i class="bi bi-cart3"></i> Move to Cart
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
