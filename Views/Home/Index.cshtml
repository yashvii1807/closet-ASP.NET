@using Closet_ASP.NET.Models
@{
    ViewData["Title"] = "Home Page";
    var products = ViewBag.Products as List<Product> ?? new List<Product>();
    var allProducts = ViewBag.AllProducts as List<Product> ?? new List<Product>();
    var pageCategory = ViewBag.PageCategory as string;
    var selMain = ViewBag.SelectedMain as string ?? "All";
    var selSub = ViewBag.SelectedSub as string ?? "All";
    var sortBy = ViewBag.SortBy as string ?? "name";
    var priceRange = ViewBag.PriceRange as string ?? "all";
    var viewMode = ViewBag.ViewMode as string ?? "grid";

    string[] subCats = { "All", "TOP", "LOWER", "SAREE" };
    string[] mainCats = { "All", "Men", "Women" };
}

<!-- HERO -->
<div class="hero-section">
    @if (string.IsNullOrEmpty(pageCategory))
    {
        <h1>Welcome to Closet</h1>
        <p>Discover the latest fashion trends and timeless classics.</p>
        <button class="shop-btn">Shop Now</button>
    }
    else
    {
        <h1>@pageCategory's Collection</h1>
        <p>Explore our curated selection for @pageCategory.ToLower().</p>
    }
</div>

<div class="container-fluid px-5">
    <div class="row">

        <!-- FILTER -->
        <div class="col-md-3">
            <div class="filter-box">
                <h5>Filters</h5>
                <hr />

                <!-- Sub Categories -->
                <p class="fw-bold mb-1">Sub Categories</p>
                @foreach (var cat in subCats)
                {
                    var count = cat == "All"
                    ? allProducts.Count
                    : allProducts.Count(p => p.SubCategory == cat);
                    <a asp-controller="Home" asp-action="Index"
                       asp-route-pageCategory="@pageCategory"
                       asp-route-selectedMainCategory="@selMain"
                       asp-route-selectedSubCategory="@cat"
                       asp-route-sortBy="@sortBy"
                       asp-route-priceRange="@priceRange"
                       class="d-block text-decoration-none @(selSub == cat ? "fw-bold text-danger" : "text-dark")">
                        @cat (@count)
                    </a>
                }

                <hr />

                <!-- Main Categories -->
                @if (string.IsNullOrEmpty(pageCategory))
                {
                    <p class="fw-bold mb-1">Main Categories</p>
                    @foreach (var cat in mainCats)
                    {
                        var count = cat == "All"
                        ? allProducts.Count
                        : allProducts.Count(p => p.MainCategory == cat);
                        <a asp-controller="Home" asp-action="Index"
                           asp-route-selectedMainCategory="@cat"
                           asp-route-selectedSubCategory="@selSub"
                           asp-route-sortBy="@sortBy"
                           asp-route-priceRange="@priceRange"
                           class="d-block text-decoration-none @(selMain == cat ? "fw-bold text-danger" : "text-dark")">
                            @cat (@count)
                        </a>
                    }
                    <hr />
                }

                <!-- Price Range -->
                <p class="fw-bold mb-1">Price Range</p>
                <form method="get" asp-action="Index">
                    <input type="hidden" name="pageCategory" value="@pageCategory" />
                    <input type="hidden" name="selectedMainCategory" value="@selMain" />
                    <input type="hidden" name="selectedSubCategory" value="@selSub" />
                    <input type="hidden" name="sortBy" value="@sortBy" />
                    <select name="priceRange" onchange="this.form.submit()" class="form-select form-select-sm mb-3">
                        @foreach (var opt in new[] {
                                                ("all",       "All Prices"),
                                                ("under500",  "Under ₹500"),
                                                ("500-1000",  "₹500 - ₹1,000"),
                                                ("1000-1500", "₹1,000 - ₹1,500"),
                                                ("1500-2000", "₹1,500 - ₹2,000"),
                                                ("above2000", "Above ₹2,000")
                                                })
                        {
                            if (priceRange == opt.Item1)
                            {
                                <option value="@opt.Item1" selected>@opt.Item2</option>
                            }
                            else
                            {
                                <option value="@opt.Item1">@opt.Item2</option>
                            }
                        }
                    </select>
                </form>

                <!-- Sort By -->
                <p class="fw-bold mb-1">Sort By</p>
                <form method="get" asp-action="Index">
                    <input type="hidden" name="pageCategory" value="@pageCategory" />
                    <input type="hidden" name="selectedMainCategory" value="@selMain" />
                    <input type="hidden" name="selectedSubCategory" value="@selSub" />
                    <input type="hidden" name="priceRange" value="@priceRange" />
                    <select name="sortBy" onchange="this.form.submit()" class="form-select form-select-sm">
                        @foreach (var opt in new[] {
                                                ("name",       "Name"),
                                                ("price-low",  "Price: Low to High"),
                                                ("price-high", "Price: High to Low"),
                                                ("rating",     "Rating")
                                                })
                        {
                            if (sortBy == opt.Item1)
                            {
                                <option value="@opt.Item1" selected>@opt.Item2</option>
                            }
                            else
                            {
                                <option value="@opt.Item1">@opt.Item2</option>
                            }
                        }
                    </select>
                </form>

            </div>
        </div>

        <!-- PRODUCTS -->
        <div class="col-md-9">
            <h3 class="mb-4">Products (@products.Count)</h3>

            @if (products.Any())
            {
                <div class="row g-4">
                    @foreach (var product in products)
                    {
                        var pid = product.Id;
                        var imgSrc = product.Images != null && product.Images.Count > 0
                        ? $"http://localhost:4000{product.Images[0]}"
                        : "https://placehold.co/400x500?text=No+Image";

                        <div class="col-md-4">
                            <div class="product-card position-relative">

                                <!-- Wishlist -->
                                <button onclick="toggleWishlist('@pid')"
                                        id="wish-@pid"
                                        class="btn btn-sm position-absolute top-0 end-0 m-2 rounded-circle bg-white border"
                                        title="Wishlist">
                                    ♡
                                </button>

                                <!-- Image -->
                                <a href="/Product/Details/@pid">
                                    <img src="@imgSrc"
                                         alt="@product.Title"
                                         onerror="this.src='https://placehold.co/400x500?text=No+Image'" />
                                </a>

                                <!-- Title -->
                                <div class="product-title">
                                    <a href="/Product/Details/@pid" class="text-decoration-none text-dark">
                                        @product.Title
                                    </a>
                                </div>

                                <!-- Category -->
                                <small class="text-muted px-2">@product.MainCategory - @product.SubCategory</small>

                                <!-- Stars -->
                                <div class="px-2 my-1">
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        <span class="@(i < Math.Floor(product.AverageRating) ? "text-warning" : "text-secondary")">★</span>
                                    }
                                    <small class="text-muted">(@product.NumRatings)</small>
                                </div>

                                <!-- Price + Cart -->
                                <div class="d-flex align-items-center justify-content-between px-2 pb-2">
                                    <strong>₹@product.Price</strong>
                                    @if (product.Stock > 0)
                                    {
                                        <a href="/Cart/Add/@pid" class="btn btn-danger btn-sm">
                                            🛒 Add
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger">Out of Stock</span>
                                    }
                                </div>

                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">No products found matching your criteria.</p>
            }
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function toggleWishlist(id) {
            const btn = document.getElementById('wish-' + id);
            btn.textContent = btn.textContent.trim() === '♡' ? '♥' : '♡';
            btn.classList.toggle('text-danger');
        }
    </script>
}