@using Closet_ASP.NET.Models
@{
    ViewData["Title"] = "Home Page";
    var products = ViewBag.Products as List<Product> ?? new List<Product>();
    var allProducts = ViewBag.AllProducts as List<Product> ?? new List<Product>();
    var pageCategory = ViewBag.PageCategory as string;
    var selMain = ViewBag.SelectedMain as string ?? "All";
    var selSub = ViewBag.SelectedSub as string ?? "All";
    var sortBy = ViewBag.SortBy as string ?? "name";
    var priceRange = ViewBag.PriceRange as string ?? "all";

    string[] subCats = { "All", "TOP", "LOWER", "SAREE" };
    string[] mainCats = { "All", "Men", "Women" };
}

<div class="container-fluid px-5 pb-4">
    
    <!-- HERO -->
    @if(string.IsNullOrEmpty(pageCategory))
    {
        <div class="hero-section">
            <h1>Welcome to Closet</h1>
            <p>Discover the latest fashion trends and timeless classics.</p>
            <button class="shop-btn">Shop Now</button>
        </div>
    }
    else
    {
        <div class="py-4 px-2" style="margin-top: 10px;">
            <h1 class="fw-bold text-dark fs-2 mb-2">@pageCategory's Collection</h1>
            <p class="text-secondary" style="font-size: 0.95rem;">Explore our curated selection for @pageCategory.ToLower().</p>
        </div>
    }

    <!-- MAIN CONTENT -->
    <div class="row mt-4">
        <!-- FILTER SIDEBAR -->
        <div class="col-md-3 pe-md-4">
            <div class="filter-box">
                <div class="filter-title">
                    <i class="bi bi-funnel text-secondary"></i> Filters
                </div>
                
                <div class="filter-label">Sub Categories</div>
                <div class="d-flex flex-column gap-1">
                    @foreach (var cat in subCats)
                    {
                        var count = cat == "All" ? allProducts.Count : allProducts.Count(p => p.Category == cat || p.SubCategory == cat);
                        <a href="?selectedSubCategory=@cat" class="category-item @(selSub == cat ? "active" : "")">
                            <span>@cat</span>
                            <span>@count</span>
                        </a>
                    }
                </div>

                @if (string.IsNullOrEmpty(pageCategory))
                {
                    <div class="filter-label">Main Categories</div>
                    <div class="d-flex flex-column gap-1">
                        @foreach (var cat in mainCats)
                        {
                            var count = cat == "All" ? allProducts.Count : allProducts.Count(p => p.MainCategory == cat);
                            <a href="?selectedMainCategory=@cat" class="category-item @(selMain == cat ? "active" : "")">
                                <span>@cat</span>
                                <span>@count</span>
                            </a>
                        }
                    </div>
                }

                <div class="filter-label">Price Range</div>
                <select id="priceRangeSelect" class="form-select form-select-sm border-0 bg-light rounded-2 py-2 px-3 shadow-none text-secondary" onchange="applyFilters()">
                    <option value="all" selected="@(ViewBag.PriceRange?.ToString() == "all")">All Prices</option>
                    <option value="under500" selected="@(ViewBag.PriceRange?.ToString() == "under500")">Under ₹500</option>
                    <option value="500-1000" selected="@(ViewBag.PriceRange?.ToString() == "500-1000")">₹500 - ₹1000</option>
                    <option value="1000-1500" selected="@(ViewBag.PriceRange?.ToString() == "1000-1500")">₹1000 - ₹1500</option>
                    <option value="1500-2000" selected="@(ViewBag.PriceRange?.ToString() == "1500-2000")">₹1500 - ₹2000</option>
                    <option value="above2000" selected="@(ViewBag.PriceRange?.ToString() == "above2000")">Above ₹2000</option>
                </select>

                <div class="filter-label">Sort By</div>
                <select id="sortBySelect" class="form-select form-select-sm border-0 bg-light rounded-2 py-2 px-3 shadow-none text-secondary" onchange="applyFilters()">
                    <option value="name" selected="@(ViewBag.SortBy?.ToString() == "name")">Name</option>
                    <option value="priceLow" selected="@(ViewBag.SortBy?.ToString() == "priceLow")">Price: Low to High</option>
                    <option value="priceHigh" selected="@(ViewBag.SortBy?.ToString() == "priceHigh")">Price: High to Low</option>
                    <option value="rating" selected="@(ViewBag.SortBy?.ToString() == "rating")">Rating</option>
                </select>
            </div>
        </div>

        <!-- PRODUCTS GRID -->
        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold mb-0 text-dark">Products <span class="text-secondary fw-normal fs-5">(@products.Count)</span></h4>
                <div class="d-flex gap-2">
                    <div class="btn btn-sm d-flex align-items-center justify-content-center rounded" style="background-color: #e2154c; color: white; width: 32px; height: 32px;">
                        <i class="bi bi-grid-fill"></i>
                    </div>
                    <div class="btn btn-sm d-flex align-items-center justify-content-center rounded bg-white border" style="color: #4a5568; width: 32px; height: 32px;">
                        <i class="bi bi-list"></i>
                    </div>
                </div>
            </div>

            @if (products.Any())
            {
                <div class="row g-4">
                    @foreach (var product in products)
                    {
                        var pid = product.Id;
                        // PUT THE URL OF THE IMAGE YOU WANT TO SHOW WHEN NO IMAGE IS AVAILABLE HERE
                        var defaultImage = "https://placehold.co/400x500?text=Your+Image+Here"; // <-- Edit this URL
                        
                        var imgSrc = product.Images != null && product.Images.Count > 0
                        ? product.Images[0]
                        : defaultImage;
                        
                        var actionText = product.Title.ToLower().Contains("saree") ? "Add" : "Select";

                        <div class="col-md-4">
                            <div class="product-card">
                                <a href="/Home/AddToWishlist/@pid" class="wishlist-btn text-dark text-decoration-none d-flex align-items-center justify-content-center">
                                    <i class="bi bi-heart"></i>
                                </a>
                                
                                <a href="/Home/Details/@pid">
                                    <!-- Replace this onerror path if you have a local image in wwwroot/images/ -->
                                    <img src="@imgSrc" alt="@product.Title" onerror="this.src='@defaultImage'" />
                                </a>
                                
                                <div class="product-title">@product.Title</div>
                                <div class="product-subtitle">@product.MainCategory - @product.Category</div>
                                
                                <div class="product-rating d-flex align-items-center gap-2 mb-2" data-product-id="@pid">
                                    <div class="stars d-flex cursor-pointer text-warning">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            var starClass = (i <= Math.Round(product.AverageRating)) ? "bi-star-fill" : "bi-star text-secondary";
                                            <i class="bi @starClass star-rate" data-value="@i" style="cursor: pointer; transition: transform 0.1s;"></i>
                                        }
                                    </div>
                                    <span class="small text-secondary fw-medium avg-text">(@product.AverageRating)</span>
                                </div>
                                
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <div class="price-tag">₹@product.Price</div>
                                    <a href="/Home/AddToCart/@pid" class="btn-select-add text-decoration-none">
                                        <i class="bi bi-cart3"></i> @actionText
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.wishlist-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const icon = this.querySelector('i');
                if (icon.classList.contains('bi-heart')) {
                    icon.classList.replace('bi-heart', 'bi-heart-fill');
                    icon.classList.add('text-danger');
                } else {
                    icon.classList.replace('bi-heart-fill', 'bi-heart');
                    icon.classList.remove('text-danger');
                }
            });
        });

        // Star Rating Logic
        document.querySelectorAll('.star-rate').forEach(star => {
            star.addEventListener('mouseover', function() {
                let val = this.getAttribute('data-value');
                this.closest('.stars').querySelectorAll('.star-rate').forEach(s => {
                    if(s.getAttribute('data-value') <= val) s.classList.add('text-warning');
                });
            });

            star.addEventListener('mouseout', function() {
                let container = this.closest('.product-rating');
                let avg = Math.round(parseFloat(container.querySelector('.avg-text').innerText.replace('(', '').replace(')', '')));
                container.querySelectorAll('.star-rate').forEach(s => {
                    let v = s.getAttribute('data-value');
                    if(v > avg) s.classList.remove('text-warning');
                });
            });

            star.addEventListener('click', function() {
                let container = this.closest('.product-rating');
                let productId = container.getAttribute('data-product-id');
                let rating = this.getAttribute('data-value');
                let avgTextElem = container.querySelector('.avg-text');

                fetch('/Home/RateProduct', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `id=${productId}&rating=${rating}`
                })
                .then(res => res.json())
                .then(data => {
                    if(data.success) {
                        container.querySelectorAll('.star-rate').forEach(s => {
                            let v = s.getAttribute('data-value');
                            if(v <= Math.round(data.newAvg)) {
                               s.classList.replace('bi-star', 'bi-star-fill');
                               s.classList.add('text-warning');
                               s.classList.remove('text-secondary');
                            } else {
                               s.classList.replace('bi-star-fill', 'bi-star');
                               s.classList.remove('text-warning');
                               s.classList.add('text-secondary');
                            }
                        });
                        avgTextElem.innerText = `(${data.newAvg})`;
                    }
                });
            });
        });

        // Filtering Logic
        function applyFilters() {
            const price = document.getElementById('priceRangeSelect').value;
            const sort = document.getElementById('sortBySelect').value;
            const urlParams = new URLSearchParams(window.location.search);
            
            if (price && price !== 'all') {
                urlParams.set('priceRange', price);
            } else {
                urlParams.delete('priceRange');
            }

            if (sort && sort !== 'name') {
                urlParams.set('sortBy', sort);
            } else {
                urlParams.delete('sortBy');
            }
            
            window.location.search = urlParams.toString();
        }
    </script>
}