@{
}
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login - Closet</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(90deg, #f3ebe6, #e8dff3);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .login-container {
            width: 900px;
            border-radius: 25px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            display: flex;
        }

        .left-panel {
            flex: 1;
            background: linear-gradient(180deg, #ff2e63, #ff9a00);
            color: white;
            padding: 60px;
        }

        .left-panel h2 {
            font-weight: bold;
            margin-top: 20px;
        }

        .right-panel {
            flex: 1;
            background: #f3f3f3;
            padding: 60px;
        }

        .form-control {
            border-radius: 12px;
            padding: 12px;
        }

        .btn-login {
            background-color: #e91e63;
            border: none;
            padding: 12px;
            border-radius: 12px;
            width: 100%;
            color: white;
            font-weight: 600;
        }

        .btn-login:hover {
            background-color: #d81b60;
        }
    </style>
</head>

<body>

    <div class="login-container">

        <!-- LEFT SIDE -->
        <div class="left-panel">
            <small>CLOSET</small>
            <h2>Welcome back<br />to your Closet.</h2>
            <p class="mt-4">
                Sign in to continue exploring curated looks, wishlist your favourites, and checkout in a few clicks.
            </p>

            <ul class="mt-5">
                <li>Secure login with your Closet account</li>
                <li>Access orders, wishlist and personalized picks</li>
            </ul>
        </div>

        <!-- RIGHT SIDE -->
        <div class="right-panel">
            <div class="d-flex mb-4 gap-2">
                <button type="button" class="btn btn-danger flex-fill active px-3 rounded-pill" id="btnUser" onclick="switchRole('User')" style="font-weight: 600;">User Login</button>
                <button type="button" class="btn btn-outline-dark flex-fill px-3 rounded-pill" id="btnAdmin" onclick="switchRole('Admin')" style="font-weight: 600;">Admin Login</button>
            </div>
            
            <h3 id="formTitle">Sign in as User</h3>
            <p>
                New here?
                <a href="Register" class="text-danger">Create an account</a>
            </p>
            <form action="/Home/Login" method="post">
                <input type="hidden" name="role" id="roleInput" value="User" />
                <div class="mb-3 mt-4">
                    <label>Email address</label>
                    <input type="email" name="email" class="form-control" placeholder="you@example.com" required />
                </div>

                <div class="mb-3">
                    <label>Password</label>
                    <input type="password" name="password" class="form-control" placeholder="Enter your password" required />
                </div>

                <div class="mb-3">
                    <small>Forgot password?</small>
                </div>

                <button type="submit" class="btn-login" id="submitBtn">Sign in as User</button>
            </form>
        </div>

    </div>

    <script>
        function switchRole(role) {
            document.getElementById('roleInput').value = role;
            if (role === 'Admin') {
                document.getElementById('btnAdmin').classList.replace('btn-outline-dark', 'btn-dark');
                document.getElementById('btnUser').classList.replace('btn-danger', 'btn-outline-danger');
                document.getElementById('formTitle').innerText = 'Sign in as Admin';
                document.getElementById('submitBtn').innerText = 'Sign in as Admin';
                document.getElementById('submitBtn').style.backgroundColor = '#212529';
            } else {
                document.getElementById('btnUser').classList.replace('btn-outline-danger', 'btn-danger');
                document.getElementById('btnAdmin').classList.replace('btn-dark', 'btn-outline-dark');
                document.getElementById('formTitle').innerText = 'Sign in as User';
                document.getElementById('submitBtn').innerText = 'Sign in as User';
                document.getElementById('submitBtn').style.backgroundColor = '#e91e63';
            }
        }
    </script>
</body>
</html>