@{
    ViewData["Title"] = "Shopping Cart";
    var cartItems = ViewBag.CartItems as List<Closet_ASP.NET.Models.Product> ?? new List<Closet_ASP.NET.Models.Product>();
}

<div class="container-fluid px-5 py-5" style="min-height: 60vh;">
    @if (cartItems.Count == 0)
    {
        <!-- Empty Cart -->
        <div class="d-flex flex-column align-items-center justify-content-center text-center py-5">
            <div class="mb-4" style="color: #cbd5e1;">
                <svg width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <path d="M16 10a4 4 0 0 1-8 0"></path>
                </svg>
            </div>
            <h2 class="fw-bold mb-3" style="color: #1a202c; font-size: 1.8rem;">Your cart is empty</h2>
            <p class="text-secondary mb-4" style="font-size: 1.05rem;">Start shopping to add items to your cart</p>
            <a href="/" class="btn btn-danger px-4 py-3 rounded-3 fw-semibold text-white" style="background-color: #e2154c;">Continue Shopping</a>
        </div>
    }
    else
    {
        <!-- Filled Cart -->
        <h2 class="fw-bold mb-4" style="color: #1a202c; font-size: 1.8rem;">Shopping Cart</h2>
        
        <div class="row">
            <div class="col-md-8 pe-md-4">
                <div class="card border-0 shadow-sm rounded-4 mb-4 p-4">
                    @foreach(var item in cartItems)
                    {
                        var imgSrc = item.Images != null && item.Images.Count > 0 ? item.Images[0] : "https://placehold.co/400x500?text=" + item.Title;
                        <!-- Cart Item -->
                        <div class="d-flex align-items-center justify-content-between mb-3 border-bottom pb-3">
                            <div class="d-flex align-items-center gap-4">
                                <img src="@imgSrc" alt="@item.Title" class="rounded-3 object-fit-cover" style="width: 80px; height: 100px;">
                                <div>
                                    <h5 class="fw-bold mb-1" style="color: #1a202c;">@item.Title</h5>
                                    <div class="text-secondary small mb-2">Size: One Size</div>
                                    <div class="fw-semibold" style="color: #e2154c;">₹@item.Price</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-4">
                                <!-- Qty -->
                                <div class="d-flex align-items-center gap-3">
                                    <a href="/Home/UpdateQuantity?id=@item.Id&delta=-1" class="btn btn-sm text-dark fs-5 fw-bold bg-transparent border-0 p-0 text-decoration-none"><i class="bi bi-dash"></i></a>
                                    <span class="fw-bold text-danger">@item.Quantity</span>
                                    <a href="/Home/UpdateQuantity?id=@item.Id&delta=1" class="btn btn-sm text-dark fs-5 fw-bold bg-transparent border-0 p-0 text-decoration-none"><i class="bi bi-plus"></i></a>
                                </div>
                                <!-- Total -->
                                <div class="fw-bold ms-3" style="color: #1a202c; font-size: 1.1rem;">₹@(item.Price * item.Quantity)</div>
                                <!-- Remove -->
                                <a href="/Home/RemoveFromCart/@item.Id" class="text-danger bg-transparent border-0 p-0 ms-3">
                                    <i class="bi bi-trash fs-5"></i>
                                </a>
                            </div>
                        </div>
                    }
                </div>

                <a href="/" class="text-danger text-decoration-none fw-medium d-inline-block mt-2" style="color: #e2154c !important;">
                    &larr; Continue Shopping
                </a>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
                    <h5 class="fw-bold mb-4" style="color: #1a202c;">Order Summary</h5>
                    
                    @{
                        var subtotal = cartItems.Sum(i => i.Price * i.Quantity);
                        var tax = subtotal * 0.18m;
                        var total = subtotal + tax;
                    }
                    
                    <div class="d-flex justify-content-between mb-3 text-secondary" style="font-size: 0.95rem;">
                        <span>Subtotal</span>
                        <span class="fw-semibold text-dark">₹@subtotal</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 text-secondary" style="font-size: 0.95rem;">
                        <span>Shipping</span>
                        <span class="fw-semibold text-dark">Free</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4 pb-4 border-bottom text-secondary" style="font-size: 0.95rem;">
                        <span>Tax (18%)</span>
                        <span class="fw-semibold text-dark">₹@Math.Round(tax)</span>
                    </div>
                    
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold text-dark fs-5">Total</span>
                        <span class="fw-bold fs-5" style="color: #e2154c;">₹@Math.Round(total)</span>
                    </div>
                    
                    <a href="/Home/Checkout" class="btn btn-danger w-100 rounded-3 py-3 fw-semibold mb-3 text-white text-decoration-none text-center d-block" style="background-color: #e2154c;">
                        Proceed to Checkout
                    </a>
                    <a href="/Home/ClearCart" class="btn btn-light bg-white border w-100 rounded-3 py-3 fw-semibold text-dark text-decoration-none text-center d-block">
                        Clear Cart
                    </a>
                </div>
            </div>
        </div>
    }
</div>
