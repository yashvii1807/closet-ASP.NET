@{
}
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Register - Closet</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(90deg, #f3ebe6, #e8dff3);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .register-container {
            width: 950px;
            border-radius: 25px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            display: flex;
        }

        .left-panel {
            flex: 1;
            background: linear-gradient(180deg, #ff2e63, #ff9a00);
            color: white;
            padding: 60px;
        }

            .left-panel h2 {
                font-weight: bold;
                margin-top: 20px;
            }

        .right-panel {
            flex: 1;
            background: #f3f3f3;
            padding: 50px;
        }

        .form-control {
            border-radius: 12px;
            padding: 12px;
        }

        .btn-register {
            background-color: #e91e63;
            border: none;
            padding: 12px;
            border-radius: 12px;
            width: 100%;
            color: white;
            font-weight: 600;
        }

            .btn-register:hover {
                background-color: #d81b60;
            }

        .profile-circle {
            width: 100px;
            height: 100px;
            background: #dcdcdc;
            border-radius: 50%;
            margin: 20px auto;
        }
    </style>
</head>

<body>

    <div class="register-container">

        <!-- LEFT PANEL -->
        <div class="left-panel">
            <small>CLOSET</small>
            <h2>Join the Closet<br />fashion circle.</h2>

            <p class="mt-4">
                Create your account to save looks, track your orders and get personalized recommendations.
            </p>

            <ul class="mt-5">
                <li>Build your wishlist and save your favourites</li>
                <li>Faster checkout and order tracking</li>
            </ul>
        </div>

        <!-- RIGHT PANEL -->
        <div class="right-panel">
            <div class="d-flex mb-4 gap-2">
                <button type="button" class="btn btn-danger flex-fill active px-3 rounded-pill" id="btnUser" onclick="switchRole('User')" style="font-weight: 600;">User Register</button>
                <button type="button" class="btn btn-outline-dark flex-fill px-3 rounded-pill" id="btnAdmin" onclick="switchRole('Admin')" style="font-weight: 600;">Admin Register</button>
            </div>

            <h3 id="formTitle">Create your User account</h3>
            <p>
                Already have an account?
                <a href="Login" class="text-danger">Sign in</a>
            </p>
            <div class="profile-circle"></div>

            <form action="/Home/Register" method="post">
                <input type="hidden" name="role" id="roleInput" value="User" />
                <div class="mb-3">
                    <label>Full Name</label>
                    <input type="text" name="fullName" class="form-control" placeholder="Enter your full name" required />
                </div>

                <div class="mb-3">
                    <label>Email address</label>
                    <input type="email" name="email" class="form-control" placeholder="you@example.com" required />
                </div>

                <div class="mb-3">
                    <label>Phone Number</label>
                    <input type="text" name="phone" class="form-control" placeholder="Enter your phone number" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label>Password</label>
                        <input type="password" name="password" class="form-control" placeholder="Enter your password" required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Confirm Password</label>
                        <input type="password" name="confirmPassword" class="form-control" placeholder="Re-enter password" required />
                    </div>
                </div>

                <button type="submit" class="btn-register" id="submitBtn">Create User Account</button>

            </form>

        </div>

    </div>

    <script>
        function switchRole(role) {
            document.getElementById('roleInput').value = role;
            if (role === 'Admin') {
                document.getElementById('btnAdmin').classList.replace('btn-outline-dark', 'btn-dark');
                document.getElementById('btnUser').classList.replace('btn-danger', 'btn-outline-danger');
                document.getElementById('formTitle').innerText = 'Create your Admin account';
                document.getElementById('submitBtn').innerText = 'Create Admin Account';
                document.getElementById('submitBtn').style.backgroundColor = '#212529';
            } else {
                document.getElementById('btnUser').classList.replace('btn-outline-danger', 'btn-danger');
                document.getElementById('btnAdmin').classList.replace('btn-dark', 'btn-outline-dark');
                document.getElementById('formTitle').innerText = 'Create your User account';
                document.getElementById('submitBtn').innerText = 'Create User Account';
                document.getElementById('submitBtn').style.backgroundColor = '#e91e63';
            }
        }
    </script>
</body>
</html>